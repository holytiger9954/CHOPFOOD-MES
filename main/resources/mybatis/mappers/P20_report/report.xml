<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.P20_report">

    <!-- AI 품질 리포트 요약 카드 -->
    <select id="selectQualitySummary"
            parameterType="qualityReportSearchDTO"
            resultType="qualityReportSummaryDTO">

        SELECT
            NVL(SUM(prod_qty), 0) AS totalQcQty,
            NVL(SUM(prod_qty - defect_qty), 0) AS totalPassQty,
            NVL(SUM(defect_qty), 0) AS totalDefectQty,

            ROUND(
                NVL(SUM(defect_qty) / NULLIF(SUM(prod_qty), 0) * 100, 0),
                1
            ) AS defectRate,

            NVL(SUM(CASE WHEN risk_level = 'HIGH' THEN 1 ELSE 0 END), 0)
                AS highRiskCount,

            ROUND(
                NVL(
                    SUM(CASE WHEN risk_level = 'HIGH' THEN 1 ELSE 0 END)
                    / NULLIF(COUNT(*), 0) * 100,
                    0
                ),
                1
            ) AS highRiskRate

        FROM ai_quality_data
        WHERE 1 = 1

        <include refid="qualitySearchCondition" />

    </select>

    <!-- 상세 리스트 전체 개수 -->
    <select id="selectQualityReportCount"
            parameterType="qualityReportSearchDTO"
            resultType="int">

        SELECT COUNT(*)
        FROM ai_quality_data
        WHERE 1 = 1

        <include refid="qualitySearchCondition" />

    </select>

    <!-- AI 품질 리포트 상세 리스트: 공통 페이지네이션 적용 -->
    <select id="selectQualityReportList"
            resultType="qualityReportListDTO">

        SELECT *
        FROM (
            SELECT
                ROWNUM AS rn,
                A.*
            FROM (
                SELECT
                    ai_data_id AS lotId,
                    item_id AS itemName,

                    prod_qty AS qcQty,
                    prod_qty - defect_qty AS qcPassQty,
                    defect_qty AS defectQty,
                    defect_rate AS defectRate,

                    equipment_id AS equipmentId,
                    temperature AS temperature,
                    humidity AS humidity,
                    equipment_runtime AS equipmentRuntime,
                    work_shift AS workShift,
                    risk_level AS riskLevel,

                    CASE
                        WHEN result_yn = 'Y' THEN '정상'
                        WHEN result_yn = 'N' THEN '불량'
                        ELSE result_yn
                    END AS qcResult,

                    TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') AS qcDate

                FROM ai_quality_data
                WHERE 1 = 1

                <include refid="qualitySearchConditionForMap" />

                ORDER BY created_at DESC, ai_data_id DESC
            ) A
            WHERE ROWNUM <![CDATA[ <= ]]> #{page.endRow}
        )
        WHERE rn <![CDATA[ >= ]]> #{page.startRow}

    </select>

    <!-- 품목 목록 -->
    <select id="selectItemList"
            resultType="reportSelectDTO">

        SELECT DISTINCT
            item_id AS code,
            item_id AS name
        FROM ai_quality_data
        ORDER BY item_id

    </select>

    <!-- 설비 목록 -->
    <select id="selectEquipmentList"
            resultType="reportSelectDTO">

        SELECT DISTINCT
            equipment_id AS code,
            equipment_id AS name
        FROM ai_quality_data
        ORDER BY equipment_id

    </select>

    <!-- 날짜별 평균 불량률 추이 -->
    <select id="selectDefectTrendList"
            parameterType="qualityReportSearchDTO"
            resultType="map">

        SELECT
            TO_CHAR(created_at, 'YYYY-MM-DD') AS "reportDate",
            ROUND(AVG(defect_rate), 2) AS "avgDefectRate"
        FROM ai_quality_data
        WHERE 1 = 1

        <include refid="qualitySearchCondition" />

        GROUP BY TO_CHAR(created_at, 'YYYY-MM-DD')
        ORDER BY "reportDate"

    </select>

    <!-- 위험도 분포 -->
    <select id="selectRiskChartList"
            parameterType="qualityReportSearchDTO"
            resultType="map">

        SELECT
            risk_level AS "riskLevel",
            COUNT(*) AS "count"
        FROM ai_quality_data
        WHERE 1 = 1

        <include refid="qualitySearchCondition" />

        GROUP BY risk_level

        ORDER BY
            CASE risk_level
                WHEN 'LOW' THEN 1
                WHEN 'MEDIUM' THEN 2
                WHEN 'HIGH' THEN 3
                ELSE 4
            END

    </select>

    <!-- 검색 조건: parameterType이 QualityReportSearchDTO일 때 -->
    <sql id="qualitySearchCondition">

        <if test="startDate != null and startDate != ''">
            AND created_at <![CDATA[ >= ]]>
                TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>

        <if test="endDate != null and endDate != ''">
            AND created_at <![CDATA[ < ]]>
                TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
        </if>

        <if test="itemId != null and itemId != ''">
            AND item_id = #{itemId}
        </if>

        <if test="equipmentId != null and equipmentId != ''">
            AND equipment_id = #{equipmentId}
        </if>

        <if test="riskLevel != null and riskLevel != ''">
            AND risk_level = #{riskLevel}
        </if>

    </sql>

    <!-- 검색 조건: paramMap 안에 searchDTO가 search로 들어갔을 때 -->
    <sql id="qualitySearchConditionForMap">

        <if test="search.startDate != null and search.startDate != ''">
            AND created_at <![CDATA[ >= ]]>
                TO_DATE(#{search.startDate}, 'YYYY-MM-DD')
        </if>

        <if test="search.endDate != null and search.endDate != ''">
            AND created_at <![CDATA[ < ]]>
                TO_DATE(#{search.endDate}, 'YYYY-MM-DD') + 1
        </if>

        <if test="search.itemId != null and search.itemId != ''">
            AND item_id = #{search.itemId}
        </if>

        <if test="search.equipmentId != null and search.equipmentId != ''">
            AND equipment_id = #{search.equipmentId}
        </if>

        <if test="search.riskLevel != null and search.riskLevel != ''">
            AND risk_level = #{search.riskLevel}
        </if>

    </sql>

</mapper>