<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE tiles-definitions PUBLIC
"-//Apache Software Foundation//DTD Tiles Configuration 2.0//EN"
"http://tiles.apache.org/dtds/tiles-config_2_0.dtd">
<tiles-definitions>

	<definition name="baseLayout" template="/WEB-INF/views/P00_layout/layout.jsp">
		<put-attribute name="header" value="/WEB-INF/views/common/header.jsp" />
		<put-attribute name="snb" value="/WEB-INF/views/common/snb.jsp" />
		<put-attribute name="title" value="chopchop" />
	</definition>
	
	<definition name="home.tiles" extends="baseLayout">
    	<put-attribute name="content" value="/WEB-INF/views/home.jsp" />
    	<put-attribute name="title" value="chopchop - home" />
	</definition>
	
	<definition name="*/*.tiles" extends="baseLayout">
    	<put-attribute name="content" value="/WEB-INF/views/{1}/{2}.jsp" />
    	<put-attribute name="title" value="{1}-{2}" />
	</definition>

</tiles-definitions>






